---
import { generateQrPattern } from '../lib/qrPattern';

interface Props {
  url: string;
  label: string;
}

const { url, label } = Astro.props;

const SIZE = 21;
const CELL = 10;
const grid = generateQrPattern(url, SIZE);

function inFinderZone(x: number, y: number): boolean {
  const isTopLeft = x < 8 && y < 8;
  const isTopRight = x >= SIZE - 8 && y < 8;
  const isBottomLeft = x < 8 && y >= SIZE - 8;
  return isTopLeft || isTopRight || isBottomLeft;
}

function finderPattern(originX: number, originY: number) {
  return [
    { x: originX, y: originY, w: 7, h: 7, fill: 'var(--color-charcoal)' },
    { x: originX + 1, y: originY + 1, w: 5, h: 5, fill: 'var(--color-cream-card)' },
    { x: originX + 2, y: originY + 2, w: 3, h: 3, fill: 'var(--color-charcoal)' },
  ];
}

const finders = [
  ...finderPattern(0, 0),
  ...finderPattern(SIZE - 7, 0),
  ...finderPattern(0, SIZE - 7),
];
---
<div class="qr-simulator">
  <svg viewBox={`0 0 ${SIZE * CELL} ${SIZE * CELL}`} role="img" aria-label={`Mã QR mô phỏng cho ${label}`}>
    <rect x="0" y="0" width={SIZE * CELL} height={SIZE * CELL} fill="var(--color-cream-card)" />
    {grid.map((row, y) =>
      row.map((filled, x) =>
        filled && !inFinderZone(x, y) ? (
          <rect x={x * CELL} y={y * CELL} width={CELL} height={CELL} fill="var(--color-charcoal)" />
        ) : null
      )
    )}
    {finders.map((f) => (
      <rect x={f.x * CELL} y={f.y * CELL} width={f.w * CELL} height={f.h * CELL} fill={f.fill} />
    ))}
  </svg>
  <p class="qr-simulator__url">{url}</p>
  <p class="mock-label">Mô phỏng - không phải mã QR thật</p>
</div>

<style>
  .qr-simulator {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-2);
    padding: var(--space-4);
    background: var(--color-cream-card);
    border-radius: var(--radius-card);
    border: 1px solid var(--color-sage);
  }
  .qr-simulator svg {
    width: 160px;
    height: 160px;
  }
  .qr-simulator__url {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-charcoal-soft);
    word-break: break-all;
    margin: 0;
    max-width: 220px;
  }
</style>
