---
import Layout from '../components/Layout.astro';
import ProductCard from '../components/ProductCard.astro';
import ProductImage from '../components/ProductImage.astro';
import { withBase } from '../lib/base';
import { products } from '../data/products';

const journeySteps = [
  {
    label: 'Mở khóa',
    description: 'Quét mã trên sản phẩm để mở khóa hành trình vật liệu, từ nguồn gốc đến ngày may hoàn thiện.',
    href: withBase('he-sinh-thai/') + '#kham-pha',
  },
  {
    label: 'Khám phá',
    description: 'Theo dõi từng chặng đường của chất liệu, quy trình dệt may và những con người phía sau sản phẩm.',
    href: withBase('he-sinh-thai/') + '#kham-pha',
  },
  {
    label: 'Tham gia',
    description: 'Tham gia workshop, sự kiện thu hồi và các hoạt động cộng đồng của Ametia Green.',
    href: withBase('he-sinh-thai/') + '#tham-gia',
  },
  {
    label: 'Lan tỏa',
    description: 'Chia sẻ hành trình mặc bền vững của bạn để lan tỏa lựa chọn rõ ràng hơn tới nhiều người khác.',
    href: withBase('he-sinh-thai/') + '#lan-toa',
  },
];

const productLifeCycle = [
  {
    title: 'Khai thác nguyên liệu',
    description: 'Ưu tiên polyester tái chế và cotton hữu cơ có nguồn gốc rõ ràng (ví dụ Cotton BCI, Organic Cotton).',
  },
  {
    title: 'Sản xuất',
    description: 'Thiết kế, cắt may và kiểm định chất lượng. Mỗi sản phẩm được gắn một mã QR riêng để truy xuất hành trình.',
  },
  {
    title: 'Phân phối & vận chuyển',
    description: 'Vận chuyển đến cửa hàng hoặc khách hàng, kèm mã QR dẫn tới website hiển thị chất liệu sử dụng, nơi sản xuất, quy trình sản xuất và hành trình vận chuyển.',
  },
  {
    title: 'Sử dụng',
    description: 'Khách hàng có thể quét QR để xem thông tin sản phẩm và cập nhật các hoạt động mới nhất của thương hiệu.',
  },
  {
    title: 'Hết vòng đời',
    description: 'Khuyến khích tái sử dụng, trao đổi hoặc chuyển nhượng để kéo dài vòng đời sản phẩm. Thương hiệu không thu hồi hay tái chế, mà tập trung vào minh bạch toàn bộ hành trình sản phẩm.',
  },
];
---
<Layout title="Trang chủ" description="Ametia Green - Green Capsule Collection, thời trang ứng dụng có trách nhiệm.">
  <section class="hero container">
    <div class="hero__content">
      <h1>Mặc lâu hơn. Chọn rõ hơn.</h1>
      <p class="hero__intro">
        Ametia Green thiết kế thời trang ứng dụng dễ phối, bền theo thời gian và minh bạch về nguồn gốc từng chất liệu.
        Mỗi sản phẩm trong bộ sưu tập Green Capsule đi kèm hành trình vật liệu rõ ràng để bạn chọn lựa an tâm hơn.
      </p>
      <a class="btn btn-primary" href={withBase('he-sinh-thai/')}>Khám phá hành trình sản phẩm</a>
    </div>
    <div class="hero__art">
      <ProductImage
        name="hero-collection"
        seed="hero-collection"
        caption="Green Capsule Collection"
        expectedFile="hero-collection.jpg"
        aspect="portrait"
      />
    </div>
  </section>

  <section class="intro eyebrow-free-section container" id="ve-ametia-green">
    <div class="intro__head">
      <p class="intro__eyebrow">Về Ametia Green</p>
      <h2>Thời trang ứng dụng có trách nhiệm cho người trẻ đi làm</h2>
      <p class="intro__lead">
        Ametia Green ra đời từ mong muốn làm thời trang ứng dụng gọn gàng, dễ mặc hàng ngày
        mà vẫn có trách nhiệm với môi trường xung quanh. Chúng tôi ưu tiên chất liệu có nguồn gốc
        rõ ràng, quy trình sản xuất tinh gọn và thông tin sản phẩm minh bạch thay vì những lời hứa mơ hồ.
      </p>
    </div>

    <div class="intro__rows">
      <article class="intro__row">
        <div class="intro__media">
          <img src={withBase('images/lifestyle/intro-1.jpg')} alt="Người mặc áo khoác mỏng Ametia Green" loading="lazy" decoding="async" width="1000" height="1326" />
        </div>
        <div class="intro__text">
          <h3>Dành cho người trẻ đi làm</h3>
          <p>
            Ametia Green được xây dựng cho người trẻ đi làm cần những món đồ dễ phối, mặc được lâu dài
            và không chạy theo vòng xoay của thời trang nhanh. Thay vì đổi tủ đồ theo mùa, bạn có thể mặc
            đi làm, đi gặp bạn bè hay đi công tác mà không phải suy nghĩ nhiều.
          </p>
          <p>
            Đây không phải thời trang xa xỉ hay trình diễn, mà là quần áo thực dụng, chỉn chu, hợp với
            nhịp sống bận rộn nhưng vẫn quan tâm đến tác động của những gì mình mua.
          </p>
        </div>
      </article>

      <article class="intro__row intro__row--reverse">
        <div class="intro__media">
          <img src={withBase('images/lifestyle/intro-2.jpg')} alt="Người mặc áo thun form rộng cùng túi tote Ametia Green" loading="lazy" decoding="async" width="1000" height="1326" />
        </div>
        <div class="intro__text">
          <h3>Triết lý thiết kế capsule</h3>
          <p>
            Chúng tôi thiết kế theo hướng capsule wardrobe: một số lượng món đồ vừa đủ, được tính toán
            để dễ dàng phối lẫn với nhau. Màu sắc, form dáng và chất liệu được chọn để một chiếc áo có thể
            đi cùng nhiều chiếc quần, và ngược lại.
          </p>
          <p>
            Mục tiêu ưu tiên là dùng được lâu dài thay vì mua nhiều rồi bỏ. Một sản phẩm tốt, được chăm sóc
            đúng cách, nên đồng hành với bạn qua nhiều mùa.
          </p>
        </div>
      </article>

      <article class="intro__row">
        <div class="intro__media">
          <img src={withBase('images/lifestyle/intro-3.jpg')} alt="Người mặc áo sơ mi tay ngắn và đội mũ lưỡi trai Ametia Green" loading="lazy" decoding="async" width="1000" height="1326" />
        </div>
        <div class="intro__text">
          <h3>Cam kết minh bạch</h3>
          <p>
            Chúng tôi cam kết minh bạch về nguồn gốc nguyên liệu và quy trình làm ra sản phẩm, kể cả những
            phần chưa hoàn thiện. Với mỗi sản phẩm, chúng tôi công khai chất liệu, hành trình sản xuất và
            cách chăm sóc.
          </p>
          <p>
            Trong bản dựng này, một số thông tin vận hành vẫn ở dạng minh họa và luôn được gắn nhãn
            <span class="mock-label">Thông tin mô phỏng</span> để bạn dễ phân biệt với dữ liệu thật.
          </p>
        </div>
      </article>
    </div>
  </section>

  <section class="lifecycle eyebrow-free-section">
    <div class="container">
      <p class="lifecycle__eyebrow">Product Life Cycle</p>
      <h2>Vòng đời một sản phẩm Ametia Green</h2>
      <p class="lifecycle__intro">
        Từ nguyên liệu đến khi kết thúc vòng đời, mỗi sản phẩm đi qua năm chặng minh bạch.
        Mã QR đồng hành cùng bạn để tra cứu nguồn gốc và hành trình bất cứ lúc nào.
      </p>
      <ol class="lifecycle__list">
        {productLifeCycle.map((step, index) => (
          <li class="lifecycle__step">
            <span class="lifecycle__num">{`0${index + 1}`}</span>
            <div class="lifecycle__body">
              <h3 class="lifecycle__title">{step.title}</h3>
              <p class="lifecycle__desc">{step.description}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  <section class="collection eyebrow-free-section container">
    <h2>Bộ sưu tập Green Capsule</h2>
    <div class="collection__grid">
      {products.map((product) => (
        <ProductCard product={product} />
      ))}
    </div>
  </section>

  <section class="journey eyebrow-free-section container">
    <h2>Hành trình hệ sinh thái</h2>
    <div class="journey__grid">
      {journeySteps.map((step, index) => (
        <a
          class="journey__item"
          class:list={{ 'journey__item--wide': index === 0 }}
          href={step.href}
        >
          <span class="journey__label">{step.label}</span>
          <p class="journey__description">{step.description}</p>
        </a>
      ))}
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    gap: var(--space-6);
    align-items: center;
    padding-block: var(--space-7);
  }
  .hero__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-4);
  }
  .hero__content h1 {
    font-size: clamp(2.1rem, 6vw, 3.2rem);
    max-width: 14ch;
  }
  .hero__intro {
    color: var(--color-charcoal-soft);
    max-width: 50ch;
    font-size: 1.05rem;
  }
  .hero__art {
    justify-self: center;
    width: 100%;
    max-width: 380px;
    padding: var(--space-4);
    background: linear-gradient(160deg, var(--color-sage-soft), var(--color-cream-card));
    border: 1px solid var(--color-line);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }
  .hero__art :global(.product-image),
  .hero__art :global(.placeholder-art) {
    box-shadow: var(--shadow-lift);
  }

  .collection h2,
  .journey h2 {
    margin-bottom: var(--space-4);
  }

  /* Introduction (moved from the standalone Giới thiệu page) */
  .intro__head {
    max-width: 62ch;
    margin-bottom: var(--space-7);
  }
  .intro__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-moss);
    margin: 0 0 var(--space-2);
  }
  .intro__lead {
    color: var(--color-charcoal-soft);
    font-size: 1.05rem;
    margin-top: var(--space-3);
  }
  .intro__rows {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }
  .intro__row {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    align-items: center;
  }
  .intro__media {
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-cream-2);
    box-shadow: var(--shadow-card);
  }
  .intro__media img {
    width: 100%;
    height: auto;
    display: block;
  }
  .intro__text h3 {
    font-size: 1.3rem;
    margin-bottom: var(--space-3);
  }
  .intro__text p {
    color: var(--color-charcoal-soft);
  }
  .intro__text p:last-child { margin-bottom: 0; }

  .collection__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }

  /* Product Life Cycle */
  .lifecycle {
    background: var(--color-sage-soft);
  }
  .lifecycle__eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-moss);
    margin: 0 0 var(--space-2);
  }
  .lifecycle__intro {
    color: var(--color-charcoal-soft);
    max-width: 60ch;
    margin-bottom: var(--space-6);
  }
  .lifecycle__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    counter-reset: lifecycle;
  }
  .lifecycle__step {
    display: flex;
    gap: var(--space-4);
    background: var(--color-cream-card);
    border: 1px solid var(--color-line);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--space-5);
  }
  .lifecycle__num {
    font-family: var(--font-mono);
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-on-moss);
    background: var(--color-moss);
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
  }
  .lifecycle__body { min-width: 0; }
  .lifecycle__title {
    font-size: 1.05rem;
    margin: 0 0 var(--space-1);
  }
  .lifecycle__desc {
    margin: 0;
    color: var(--color-charcoal-soft);
    font-size: 0.95rem;
    max-width: none;
  }

  .journey__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }
  .journey__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    background: var(--color-cream-card);
    border-radius: var(--radius-card);
    padding: var(--space-5);
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s ease;
  }
  .journey__item:hover {
    transform: translateY(-2px);
  }
  .journey__label {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--color-moss);
  }
  .journey__description {
    margin: 0;
    color: var(--color-charcoal-soft);
    font-size: 0.95rem;
  }

  @media (min-width: 600px) {
    .collection__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .journey__grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .lifecycle__list {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 900px) {
    .hero {
      grid-template-columns: 1.1fr 0.9fr;
    }
    .intro__row {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
    .intro__media {
      max-width: 440px;
      width: 100%;
      justify-self: center;
    }
    .intro__row--reverse .intro__media {
      order: 2;
    }
    .collection__grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .journey__grid {
      grid-template-columns: repeat(4, 1fr);
    }
    .journey__item--wide {
      grid-column: span 2;
    }
  }
</style>
